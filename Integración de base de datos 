import 'package:cloud_firestore/cloud_firestore.dart';

// Guardar un pokemon favorito
Future<void> guardarPokemon(String nombre, String tipo) async {
  await FirebaseFirestore.instance.collection('favoritos').add({
    'nombre': nombre,
    'tipo': tipo,
    'fecha': Timestamp.now(),
  });
}

// Leer en tiempo real
Stream<QuerySnapshot> leerFavoritos() {
  return FirebaseFirestore.instance
     .collection('favoritos')
     .orderBy('fecha', descending: true)
     .snapshots();
}

// En tu Widget:
StreamBuilder<QuerySnapshot>(
  stream: leerFavoritos(),
  builder: (context, snapshot) {
    if (!snapshot.hasData) return CircularProgressIndicator();
    final docs = snapshot.data!.docs;
    return ListView.builder(
      itemCount: docs.length,
      itemBuilder: (context, index) {
        final data = docs[index].data() as Map<String, dynamic>;
        return ListTile(title: Text(data['nombre']));
      },
    );
  },
)
